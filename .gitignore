#
# Configuration adaptée au projet Démineur en Java.
# Les fichiers compilés et de build sont ignorés, ainsi que les fichiers
# de sauvegarde générés à l'exécution.

# Fichiers compilés Java
*.class

# Dossiers de build / sortie
out/
bin/
build/

# Classes anonymes générées automatiquement par le compilateur (déjà couvertes par *.class,
# mais conservé pour clarté)
*$*.class

# Fichiers temporaires et de sauvegarde du jeu
sauvegarde.txt
meilleur_score.txt

# Logs
*.log

# OS specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs
.idea/
.vscode/
*.iml
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

